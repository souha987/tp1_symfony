{% extends 'base.html.twig' %}

{% block body %}

<h1>📰 Liste des articles</h1>

<!-- ➕ BOUTON AJOUTER -->
<a href="{{ path('app_article_nouveau') }}"
   style="display:inline-block; margin-bottom:15px; padding:8px; background:green; color:white; text-decoration:none;">
    ➕ Ajouter un article
</a>

<hr>

{% for article in articles %}

    <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">

        <h3>{{ article.titre }}</h3>

        <p>{{ article.contenu }}</p>

        <p>👤 Auteur : {{ article.auteur }}</p>

        <p>📅 {{ article.dateCreation|date('Y-m-d H:i') }}</p>

        <!-- 🔍 DÉTAIL -->
        <a href="{{ path('app_article_detail', {id: article.id}) }}">
            🔍 Détail
        </a>

        <!-- ✏️ MODIFIER -->
        <a href="{{ path('app_article_modifier', {id: article.id}) }}">
            ✏️ Modifier
        </a>

        <!-- 🗑 SUPPRIMER -->
        <form method="post"
              action="{{ path('app_article_supprimer', {id: article.id}) }}"
              style="display:inline">

            <input type="hidden" name="_token"
                   value="{{ csrf_token('supprimer_' ~ article.id) }}">

            <button type="submit"
                    onclick="return confirm('Supprimer cet article ?')">
                🗑 Supprimer
            </button>

        </form>

    </div>

{% else %}

    <p>Aucun article trouvé.</p>

{% endfor %}

{% endblock %}