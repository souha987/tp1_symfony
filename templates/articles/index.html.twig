{% extends 'base.html.twig' %}

{% block title %}📰 Liste des articles{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">📰 {{ articles|length }} Article{{ articles|length > 1 ? 's' : '' }}</h1>
            <small class="text-muted">Gestion complète des articles</small>
        </div>
        <a href="{{ path('app_article_nouveau') }}" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle me-2"></i> Nouvel article
        </a>
    </div>

    {% if articles is empty %}
        <div class="row justify-content-center">
            <div class="col-md-8 text-center py-5">
                <div class="empty-state">
                    <i class="bi bi-file-earmark-text display-1 text-muted mb-4"></i>
                    <h3 class="mb-3">Aucun article pour le moment</h3>
                    <p class="text-muted mb-4">
                        Commencez par créer votre premier article de blog !
                    </p>
                    <a href="{{ path('app_article_nouveau') }}" class="btn btn-primary btn-lg">
                        <i class="bi bi-plus-circle me-2"></i> Créer le premier
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        {# 🆕 CARDS MODERNES avec TEMPS #}
        <div class="row g-4">
            {% for article in articles %}
                <div class="col-lg-6 col-xl-4">
                    <div class="card h-100 article-card shadow-sm hover-lift">
                        <div class="card-header d-flex justify-content-between align-items-start">
                            {# Catégorie #}
                            {% if article.categorie %}
                                <span class="badge bg-info text-dark">
                                    {{ article.categorie.nom }}
                                </span>
                            {% endif %}
                            
                            {# Statut #}
                            <span class="badge {{ article.publie ? 'bg-success' : 'bg-warning text-dark' }}">
                                {{ article.publie ? '✅ Publié' : '📝 Brouillon' }}
                            </span>
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title h5 mb-2 mt-1">
                                {{ article.titre }}
                            </h3>
                            
                            <p class="card-text text-muted flex-grow-1 mb-3">
                                {{ article.contenu|striptags|slice(0, 120) }}...
                            </p>
                            
                            {# 🆕 META avec TEMPS DE LECTURE #}
                            <div class="meta-bar d-flex justify-content-between align-items-center mb-3">
                                <div class="author-date small text-muted">
                                    <i class="bi bi-person me-1"></i>
                                    {{ article.auteur }}
                                    <br>
                                    <small>
                                        <i class="bi bi-calendar me-1"></i>
                                        {{ article.dateCreation|date('d MMM Y') }}
                                    </small>
                                </div>
                                
                                {# TEMPS DE LECTURE #}
                                <span class="badge bg-primary fs-6 px-3 py-2">
                                    ⏱️ {{ article.contenu|reading_time }}
                                </span>
                            </div>
                            
                            {# Boutons #}
                            <div class="btn-group w-100" role="group">
                                <a href="{{ path('app_article_detail', {'id': article.id}) }}" 
                                   class="btn btn-outline-primary flex-fill" title="Lire">
                                    <i class="bi bi-eye me-1"></i> Voir
                                </a>
                                <a href="{{ path('app_article_modifier', {'id': article.id}) }}" 
                                   class="btn btn-outline-secondary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        
        {# 🆕 PAGINATION si besoin #}
        {% if articles|length > 10 %}
            <nav class="mt-5">
                {# Ici votre pagination #}
            </nav>
        {% endif %}
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
.article-card {
    transition: all 0.2s ease;
    border: none;
}
.article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
}
.hover-lift {
    cursor: pointer;
}
.meta-bar {
    font-size: 0.9em;
}
.card-header {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-bottom: 1px solid #dee2e6;
}
.empty-state i {
    opacity: 0.5;
}
@media (max-width: 768px) {
    .meta-bar {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5em;
    }
}
</style>
{% endblock %}