{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ article.titre }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">

        <h1 class="mb-4">✏️ Modifier l'article</h1>

        <p class="text-muted mb-4 border-bottom pb-2">
            Modification de « {{ article.titre }} »
        </p>

        {{ form_start(formulaire) }}

            <div class="mb-3">
                {{ form_row(formulaire.titre) }}
            </div>

            <div class="mb-3">
                {{ form_row(formulaire.contenu) }}
            </div>

            <div class="mb-3">
                {{ form_row(formulaire.categorie) }}
            </div>

            <div class="mb-3">
                {{ form_row(formulaire.publie) }}
            </div>

            <button class="btn btn-success">
                💾 Enregistrer
            </button>

        {{ form_end(formulaire) }}

        <a href="{{ path('app_article_detail', {id: article.id}) }}"
           class="btn btn-link text-muted mt-3">
            ← Annuler
        </a>

    </div>
</div>
{% endblock %}