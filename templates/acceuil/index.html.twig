{% extends 'base.html.twig' %}

{% block title %}🏠 Accueil - Blog Symfony{% endblock %}

{% block body %}
<div class="hero-section py-5 bg-gradient-primary text-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                {# Message personnalisé #}
                {% if app.user %}
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <i class="bi bi-person-check me-2"></i>
                        Bonjour <strong>{{ app.user.pseudo }}</strong> ! 👋
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                    </div>
                {% endif %}
                
                <h1 class="display-3 fw-bold mb-4 hero-title">
                    Bienvenue sur <span class="text-warning">Blog Symfony</span>
                </h1>
                <p class="lead mb-4 fs-4">
                    Découvrez nos derniers articles et commencez à publier dès aujourd'hui !
                </p>
                
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <a href="{{ path('app_articles') }}" class="btn btn-warning btn-lg px-5">
                        <i class="bi bi-newspaper me-2"></i> Voir tous les articles
                    </a>
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_article_nouveau') }}" class="btn btn-outline-light btn-lg px-5">
                            <i class="bi bi-plus-circle me-2"></i> Nouveau post
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    {# 🆕 DERNIERS ARTICLES avec TEMPS DE LECTURE #}
    <section class="recent-articles mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h3 mb-0">
                <i class="bi bi-lightning-charge text-primary me-2"></i>
                Articles récents
            </h2>
            <a href="{{ path('app_articles') }}" class="btn btn-outline-primary">
                Voir tout <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        
        {% set recent_articles = articles|slice(0, 6) %}
        {% if recent_articles is not empty %}
            <div class="row g-4">
                {% for article in recent_articles %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 article-preview shadow-sm hover-lift">
                            {# Header avec statut #}
                            <div class="card-header bg-transparent border-0 pt-3 px-3">
                                {% if article.categorie %}
                                    <span class="badge bg-info text-dark me-2">
                                        {{ article.categorie.nom }}
                                    </span>
                                {% endif %}
                                <span class="badge {{ article.publie ? 'bg-success' : 'bg-warning text-dark' }}">
                                    {{ article.publie ? 'Publié' : 'Brouillon' }}
                                </span>
                            </div>
                            
                            <div class="card-body d-flex flex-column p-4">
                                <h3 class="card-title h5 mb-3 fw-bold line-clamp-2">
                                    {{ article.titre }}
                                </h3>
                                
                                <p class="card-text text-muted flex-grow-1 mb-3 line-clamp-3">
                                    {{ article.contenu|striptags|slice(0, 140) }}...
                                </p>
                                
                                {# 🆕 META + TEMPS DE LECTURE #}
                                <div class="meta-row d-flex justify-content-between align-items-center mb-4">
                                    <div class="meta-left small text-muted">
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi bi-person-circle me-2 text-primary"></i>
                                            {{ article.auteur }}
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-calendar me-2 text-muted"></i>
                                            {{ article.dateCreation|date('d MMM Y') }}
                                        </div>
                                    </div>
                                    
                                    {# TEMPS DE LECTURE #}
                                    <span class="badge bg-primary px-3 py-2 fs-6 fw-semibold">
                                        ⏱️ {{ article.contenu|reading_time }}
                                    </span>
                                </div>
                                
                                <a href="{{ path('app_article_detail', {'id': article.id}) }}" 
                                   class="btn btn-outline-primary w-100 mt-auto">
                                    <i class="bi bi-arrow-right me-2"></i>
                                    Lire l'article
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-newspaper display-4 text-muted mb-4"></i>
                <h4>Aucun article publié pour le moment</h4>
                <p class="text-muted mb-4">Soyez le premier à publier !</p>
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('app_article_nouveau') }}" class="btn btn-primary btn-lg">
                        <i class="bi bi-plus-circle me-2"></i> Créer le premier
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </section>

    {# Navigation rapide #}
    <section class="quick-links py-5 bg-light rounded-3">
        <div class="row text-center">
            <div class="col-md-3 mb-3">
                <a href="{{ path('app_articles') }}" class="link-primary link-underline-opacity-0">
                    <i class="bi bi-grid-3x3-gap display-4 text-primary mb-2 d-block"></i>
                    <h5>Tous les articles</h5>
                </a>
            </div>
            {% if is_granted('ROLE_USER') %}
                <div class="col-md-3 mb-3">
                    <a href="{{ path('app_article_nouveau') }}" class="link-success link-underline-opacity-0">
                        <i class="bi bi-plus-square display-4 text-success mb-2 d-block"></i>
                        <h5>Nouvel article</h5>
                    </a>
                </div>
            {% endif %}
            <div class="col-md-3 mb-3">
                <a href="{{ path('app_taches') }}" class="link-info link-underline-opacity-0">
                    <i class="bi bi-check2-square display-4 text-info mb-2 d-block"></i>
                    <h5>Mes tâches</h5>
                </a>
            </div>
            {% if not app.user %}
                <div class="col-md-3 mb-3">
                    <a href="{{ path('app_login') }}" class="link-warning link-underline-opacity-0">
                        <i class="bi bi-box-arrow-in-right display-4 text-warning mb-2 d-block"></i>
                        <h5>Se connecter</h5>
                    </a>
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
:root {
    --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.bg-gradient-primary {
    background: var(--gradient-primary) !important;
}
.hero-title {
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}
.hover-lift {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.hover-lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
}
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
@media (max-width: 768px) {
    .hero-title {
        font-size: 2.5rem;
    }
}
</style>
{% endblock %}{% extends 'base.html.twig' %}

