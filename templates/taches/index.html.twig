{% extends 'base.html.twig' %}

{% block title %}Liste des tâches{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">✅ Gestion des tâches</h1>
        <a href="{{ path('app_tache_ajouter') }}" class="btn btn-primary">
            ➕ Nouvelle tâche
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% if taches is empty %}
        <div class="alert alert-info text-center py-5">
            <p class="mb-3">Aucune tâche pour le moment.</p>
            <a href="{{ path('app_tache_ajouter') }}" class="btn btn-primary">
                ➕ Créer une tâche
            </a>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Date création</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tache in taches %}
                        <tr {% if tache.terminee %}class="table-secondary"{% endif %}>
                            <td>{{ tache.id }}</td>
                            <td {% if tache.terminee %}style="text-decoration: line-through;"{% endif %}>
                                {{ tache.titre }}
                            </td>
                            <td>{{ tache.description|default('-') }}</td>
                            <td>{{ tache.dateCreation|date('d/m/Y H:i') }}</td>
                            <td>
                                {% if tache.terminee %}
                                    <span class="badge bg-success">✅ Terminée</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">⏳ En cours</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="{{ path('app_tache_detail', {id: tache.id}) }}" class="btn btn-outline-primary btn-sm">
                                        👁️ Voir
                                    </a>
                                    {% if not tache.terminee %}
                                        <a href="{{ path('app_tache_terminer', {id: tache.id}) }}" class="btn btn-outline-success btn-sm" 
                                           onclick="return confirm('Marquer cette tâche comme terminée ?');">
                                            ✓ Terminer
                                        </a>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_tache_supprimer', {id: tache.id}) }}" 
                                          onsubmit="return confirm('Supprimer définitivement cette tâche ?');" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('supprimer_' ~ tache.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">
                Total : {{ taches|length }} tâche(s) - 
                {% set non_terminees = taches|filter(t => not t.terminee)|length %}
                {{ non_terminees }} en cours, {{ taches|length - non_terminees }} terminée(s)
            </p>
        </div>
    {% endif %}
{% endblock %}
